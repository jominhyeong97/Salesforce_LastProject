<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Outstanding_Amount__c</fullName>
    <description>미수 잔액 (TotalAmount - 누적 입금액). FR-AR-001. Order는 Master-Detail 가 아니어서 Roll-Up Summary 불가 → Apex 가 Total_Paid_Amount__c 를 갱신하고 본 Formula 가 차감.</description>
    <externalId>false</externalId>
    <formula>NULLVALUE(TotalAmount, 0) - NULLVALUE(Total_Paid_Amount__c, 0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>미수 잔액</label>
    <precision>16</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <type>Currency</type>
    <unique>false</unique>
</CustomField>
